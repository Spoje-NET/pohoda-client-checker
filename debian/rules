#!/usr/bin/make -f

PKG_VERSION := $(shell dpkg-parsechangelog -S Version | sed 's/~.*//')
PKG_SOURCE  := $(shell jq -r '.name' composer.json)
PKG_TYPE    := $(shell jq -r '.type' composer.json)

%:
	dh $@

override_dh_auto_test:
	appstreamcli validate --pedantic --no-net \
	    debian/io.github.spoje_net.pohoda_client_checker.metainfo.xml

override_dh_install:
	dh_install
	install -m 644 debian/autoload.php \
	    debian/pohoda-client-checker/usr/share/pohoda-client-checker/autoload.php
	sed -i "s|require_once '../vendor/autoload.php'|require_once '/usr/share/pohoda-client-checker/autoload.php'|" \
	    debian/pohoda-client-checker/usr/share/pohoda-client-checker/*.php
	sed -i -e 's/\.\.\/\.env//g' \
	    debian/pohoda-client-checker/usr/share/pohoda-client-checker/*.php
	sed -i "1a defined('APP_NAME') || define('APP_NAME', '$(PKG_SOURCE)');" \
	    debian/pohoda-client-checker/usr/share/pohoda-client-checker/autoload.php
	sed -i "s|'unknown'|'$(PKG_SOURCE)'|" \
	    debian/pohoda-client-checker/usr/share/pohoda-client-checker/autoload.php
	sed -i "s|'0.0.0'|'$(PKG_VERSION)'|" \
	    debian/pohoda-client-checker/usr/share/pohoda-client-checker/autoload.php
	sed -i "s|'library'|'$(PKG_TYPE)'|g" \
	    debian/pohoda-client-checker/usr/share/pohoda-client-checker/autoload.php
	sed -i "2a defined('APP_VERSION') || define('APP_VERSION', '$(PKG_VERSION)');" \
	    debian/pohoda-client-checker/usr/share/pohoda-client-checker/autoload.php
	jq '.version = "$(PKG_VERSION)"' debian/conf/composer.json \
	    | sponge debian/pohoda-client-checker/usr/lib/pohoda-client-checker/composer.json
	jq '.version = "$(PKG_VERSION)"' multiflexi/pohoda_checker.multiflexi.app.json \
	    | sponge debian/multiflexi-pohoda-client-checker/usr/lib/pohoda-client-checker/multiflexi/pohoda_checker.multiflexi.app.json
	jq '.version = "$(PKG_VERSION)"' multiflexi/pohoda_transaction_report.multiflexi.app.json \
	    | sponge debian/multiflexi-pohoda-client-checker/usr/lib/pohoda-client-checker/multiflexi/pohoda_transaction_report.multiflexi.app.json
