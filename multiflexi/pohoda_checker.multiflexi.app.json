{
  "$schema": "https://raw.githubusercontent.com/VitexSoftware/php-vitexsoftware-multiflexi-core/refs/heads/main/multiflexi.app.schema.json",
  "schemaVersion": "3.4.0",
  "uuid": "08891f30-a0f7-43b9-8984-c8188dda9583",
  "name": {
    "en": "Pohoda Checker",
    "cs": "Pohodová zkoušečka"
  },
  "description": {
    "en": "Check Stormware mServer availbility",
    "cs": "Ověří dostupnost Stormware mServeru"
  },
  "tags": [
    "Pohoda",
    "mServer",
    "Check"
  ],
  "homepage": "https://github.com/Spoje-NET/pohoda-client-checker",
  "image": "",
  "executable": "pohoda-client-checker",
  "events": {
    "emits": {
      "client.checked": {
        "description": "Client/customer records were validated"
      }
    }
  },
  "environment": {
    "RESULT_FILE": {
      "type": "string",
      "description": {
        "en": "write output json data to",
        "cs": "zapsat výstupní json data do"
      },
      "defval": "pohoda-status.json",
      "required": false,
      "category": "Other"
    },
    "EASE_LOGGER": {
      "type": "string",
      "description": {
        "en": "write log messages using",
        "cs": "zapisovat log zprávy pomocí"
      },
      "defval": "console|syslog",
      "required": false,
      "category": "Behavior"
    },
    "APP_DEBUG": {
      "type": "bool",
      "description": {
        "en": "Show debug messages",
        "cs": "Zobrazit ladicí zprávy"
      },
      "defval": false,
      "required": true,
      "category": "Behavior"
    },
    "ZABBIX_KEY": {
      "type": "string",
      "description": {
        "en": "Default name for Zabbix Item key name",
        "cs": "Výchozí název pro klíč položky Zabbix"
      },
      "defval": "mServer-attainability-{POHODA_ICO}",
      "required": false,
      "category": "Other"
    }
  },
  "requirements": [
    "mserver"
  ]
}
